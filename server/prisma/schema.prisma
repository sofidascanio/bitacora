generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  avatar    String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks      Task[]
  notes      Note[]
  categories Category[]
}

enum Role {
  USER
  ADMIN
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  order       Int        @default(0)  // para drag & drop

  // relacion para subtareas
  parentId    String?
  parent      Task?      @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks    Task[]     @relation("TaskSubtasks")

  // relaciones
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags        TagsOnTasks[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Note {
  id         String   @id @default(cuid())
  title      String
  content    String?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  tags       TagsOnNotes[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Category {
  id          String  @id @default(cuid())
  name        String
  description String?
  color       String? // hex color para UI
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  notes       Note[]

  @@unique([name, userId]) // un usuario no puede tener dos categorias con el mismo nombre
}

model Tag {
  id    String        @id @default(cuid())
  name  String        @unique
  tasks TagsOnTasks[]
  notes TagsOnNotes[]
}

// tabla muchos-muchos Task <-> Tag
model TagsOnTasks {
  taskId String
  tagId  String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

// tabla muchos a muchos Note <-> Tag
model TagsOnNotes {
  noteId String
  tagId  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}